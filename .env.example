# ========================
# Database (PostgreSQL)
# ========================
DATABASE_URL=postgres://tft_user:tft_pass@localhost:5432/tft_oracle?sslmode=disable

# ========================
# Redis (Phase 2+)
# ========================
REDIS_URL=redis://localhost:6379/0

# ========================
# API Keys
# ========================
RIOT_API_KEY=RGAPI-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ========================
# Server
# ========================
SERVER_PORT=8080
SERVER_HOST=localhost

# ========================
# Auth (JWT)
# ========================
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRY=720h

# ========================
# Environment
# ========================
APP_ENV=development
LOG_LEVEL=debug
